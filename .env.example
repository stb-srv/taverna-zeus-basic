# Kopiervorlage für die Environment-Variablen.
# Für Coolify NICHT diese Datei hochladen, sondern die Werte im Tab
# "Environment Variables" eintragen – die Felder legt Coolify aus den
# ${...}-Referenzen in docker-compose.yml automatisch an (siehe DEPLOY.md).

# --- Supabase (Pflicht) -------------------------------------------------
# BUILD-ZEIT + Laufzeit: wird ins Client-Bundle eingebacken.
# In Coolify: "Available at Buildtime" aktivieren!
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# NUR Laufzeit, Server-only (niemals NEXT_PUBLIC_-Prefix geben!).
# Wird für privilegierte Admin-Operationen benutzt (src/lib/supabase/admin.ts).
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# BUILD-ZEIT (wie oben): Basis-URL der Live-Site, ohne trailing slash.
# Wird für metadataBase/OpenGraph/hreflang-Alternates und sitemap.xml/
# robots.txt gebraucht. In Coolify: "Available at Buildtime" aktivieren!
NEXT_PUBLIC_SITE_URL=https://example.com

# --- LibreTranslate (optional) ------------------------------------------
# NUR Laufzeit. Ohne diese Werte fällt LIBRETRANSLATE_URL auf
# http://localhost:5000 zurück (src/lib/translate.ts).
# In Coolify idealerweise die interne Service-URL des LibreTranslate-Containers.
#LIBRETRANSLATE_URL=http://libretranslate:5000
#LIBRETRANSLATE_API_KEY=

# --- E-Mail-Benachrichtigung für Kontaktformular (optional, best-effort) ---
# Eigener SMTP-Server (kein Drittanbieter). Schlägt der Versand fehl, wird die
# Nachricht trotzdem in contact_messages gespeichert (nie blockierend).
#SMTP_HOST=mail.example.com
#SMTP_PORT=587
#SMTP_USER=contact@example.com
#SMTP_PASSWORD=<secret>
#SMTP_FROM=contact@example.com
#CONTACT_NOTIFY_EMAIL=owner@example.com

# --- Datenbank-Migrationen (nur lokal, für scripts/run-sql.mjs) ---------
# Supavisor-POOLER-String (Port 6543) aus Supabase -> Project Settings ->
# Database -> Connection string. Wird NICHT im Container gebraucht.
#DATABASE_URL=postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres
