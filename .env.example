# --- Supabase -----------------------------------------------------------
# BUILD-ZEIT + Laufzeit: wird ins Client-Bundle eingebacken.
# In Coolify: "Available at Buildtime" aktivieren!
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# NUR Laufzeit, Server-only (niemals NEXT_PUBLIC_-Prefix geben!).
# Wird für privilegierte Admin-Operationen benutzt (src/lib/supabase/admin.ts).
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# --- LibreTranslate (optional) ------------------------------------------
# NUR Laufzeit. Ohne diese Werte fällt LIBRETRANSLATE_URL auf
# http://localhost:5000 zurück (src/lib/translate.ts).
# In Coolify idealerweise die interne Service-URL des LibreTranslate-Containers.
#LIBRETRANSLATE_URL=http://libretranslate:5000
#LIBRETRANSLATE_API_KEY=
